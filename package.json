{
  "name": "olx-scraper",
  "version": "2.0.0",
  "description": "OLX.pl Scraper API + MCP server",
  "main": "dist/index.js",
  "bin": {
    "olx-mcp": "dist/mcp/index.js"
  },
  "files": [
    "dist",
    "src",
    "public",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:mcp": "tsx src/mcp/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scalar/express-api-reference": "^0.8.39",
    "axios": "^1.7.0",
    "axios-cookiejar-support": "^6.0.5",
    "axios-retry": "^4.5.0",
    "bottleneck": "^2.19.5",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "lru-cache": "^11.5.1",
    "playwright": "^1.48.0",
    "swagger-jsdoc": "^6.2.8",
    "tough-cookie": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/tough-cookie": "^4.0.5",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  }
}
