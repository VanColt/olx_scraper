# Server
PORT=3000

# Scraping politeness
REQUEST_DELAY_MS=2000
PLAYWRIGHT_ENABLED=true

# Cache TTLs (seconds)
SEARCH_CACHE_TTL_S=180
PRODUCT_CACHE_TTL_S=1800
CATEGORIES_CACHE_TTL_S=86400

# --- Messaging (OLX Partner API v2 — optional) ---
# Requires an approved app on https://developer.olx.pl and an OAuth2 token
# with "v2 read write" scopes. The Partner API can only REPLY to existing
# threads; it cannot initiate contact. See README — Messaging.
# OLX_CLIENT_ID=
# OLX_CLIENT_SECRET=
# OLX_PARTNER_ACCESS_TOKEN=
# OLX_PARTNER_REFRESH_TOKEN=
